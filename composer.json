{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "aws/aws-sdk-php": "^3.376",
        "bacon/bacon-qr-code": "^3.0",
        "barryvdh/laravel-dompdf": "^3.1",
        "google/cloud-storage": "^1.50",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "league/commonmark": "^2.8",
        "league/flysystem-aws-s3-v3": "^3.32",
        "league/flysystem-ftp": "^3.31",
        "league/flysystem-google-cloud-storage": "^3.31",
        "league/flysystem-sftp-v3": "^3.33",
        "pragmarx/google2fa": "^9.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Addons\\CatWysiwyg\\": "addons/cat-wysiwyg/",
            "Addons\\CatminShop\\": "addons/catmin-shop/",
            "Addons\\CatEvent\\": "addons/cat-event/",
            "Addons\\CatminBooking\\": "addons/catmin-booking/",
            "Addons\\CatminCrmLight\\": "addons/catmin-crm-light/",
            "Addons\\CatminEventShopBridge\\": "addons/catmin-event-shop-bridge/",
            "Addons\\CatminImportExport\\": "addons/catmin-import-export/",
            "Addons\\CatminProfileExtensions\\": "addons/catmin-profile-extensions/",
            "Addons\\CatminSlider\\": "addons/catmin-slider/",
            "Addons\\CatminBackupS3\\": "addons/catmin-backup-s3/",
            "Modules\\": "modules/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Addons\\CatminMap\\": "addons/catmin-map/"
        },
        "files": [
            "app/Helpers/AdminPathHelper.php",
            "app/Helpers/CatminHelper.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "lint": [
            "bash scripts/dev/php-lint.sh"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "ci": [
            "@composer lint",
            "@composer test"
        ],
        "release:build": [
            "bash scripts/release/build-release.sh"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
