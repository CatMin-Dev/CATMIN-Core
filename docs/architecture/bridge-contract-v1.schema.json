{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catmin.dev/schemas/bridge.contract.v1.json",
  "title": "CATMIN Bridge Contract v1",
  "description": "Source de vérité contractuelle d'un bridge CATMIN. Obligatoire en CI. Fail si non conforme.",
  "type": "object",
  "required": [
    "schema_version",
    "bridge_id",
    "bridge_version",
    "min_core_version",
    "permissions",
    "widgets",
    "events",
    "dependencies",
    "migrations"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version du schéma bridge.contract (ex: 1.0.0). Incrémentée si le contrat évolue de manière incompatible.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "bridge_id": {
      "type": "string",
      "description": "Identifiant unique du bridge (ex: cat-slug). Correspond au slug du module.",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "bridge_version": {
      "type": "string",
      "description": "Version SemVer du bridge lui-même.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?(\\+[a-zA-Z0-9.]+)?$"
    },
    "min_core_version": {
      "type": "string",
      "description": "Version minimale du core CATMIN requise.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
    },
    "max_core_version": {
      "type": "string",
      "description": "Version maximale du core CATMIN supportée (optionnel, absence = pas de plafond déclaré).",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
    },
    "permissions": {
      "type": "object",
      "description": "Capabilities déclarées par ce bridge. Namespace strict: bridge_id.action. Tout accès non déclaré est bloqué par policy.",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z][a-z0-9-]+\\.(read|write|delete|admin|sync|publish|draft|restore|reorder)$": {
          "type": "object",
          "required": ["label", "scope"],
          "additionalProperties": false,
          "properties": {
            "label": {
              "type": "string",
              "description": "Libellé humain de la capability (pour dashboard droits)."
            },
            "scope": {
              "type": "string",
              "enum": ["read", "write", "delete", "admin", "sync", "publish", "draft", "restore", "reorder"],
              "description": "Type d'accès."
            },
            "description": {
              "type": "string",
              "description": "Description détaillée de ce que permet cette capability."
            },
            "roles_default": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Rôles auxquels cette capability est assignée par défaut à l'activation du bridge."
            }
          }
        }
      }
    },
    "widgets": {
      "type": "array",
      "description": "Déclaration contractuelle des widgets/snippets/blocs exposés par le bridge. La déclaration vit dans bridge.contract.json ; le dossier widgets/ sert uniquement d'implémentation.",
      "items": {
        "type": "object",
        "required": ["name", "type", "scope", "permissions", "entry"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Nom fonctionnel unique du composant UI (widget/snippet/block)."
          },
          "type": {
            "type": "string",
            "enum": ["widget", "snippet", "block"]
          },
          "scope": {
            "type": "string",
            "enum": ["admin", "frontend", "both"]
          },
          "permissions": {
            "type": "array",
            "description": "Capabilities requises pour exposer ou utiliser ce composant UI.",
            "items": { "type": "string" },
            "minItems": 1
          },
          "entry": {
            "type": "string",
            "description": "Chemin de fichier ou classe d'entrée côté implémentation (ex: widgets/seo-score-meter.php)."
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "events": {
      "type": "object",
      "description": "Événements émis et écoutés par ce bridge.",
      "required": ["emits", "listens"],
      "additionalProperties": false,
      "properties": {
        "emits": {
          "type": "array",
          "description": "Événements que ce bridge publie (hook/event name).",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "payload_schema": { "type": "object" }
            }
          }
        },
        "listens": {
          "type": "array",
          "description": "Événements que ce bridge consomme.",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "source_bridge": { "type": "string" }
            }
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "description": "Routes admin/API exposées par ce bridge.",
      "items": {
        "type": "object",
        "required": ["method", "path", "permission"],
        "additionalProperties": false,
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          },
          "path": {
            "type": "string",
            "description": "Chemin relatif au préfixe admin. Ex: /slugs/{entity}/{id}"
          },
          "permission": {
            "type": "string",
            "description": "Capability requise (bridge_id.action). Doit être déclarée dans permissions."
          },
          "description": { "type": "string" },
          "middleware": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Dépendances du bridge. Un bridge ne peut dépendre que d'autres bridges (jamais de modules maîtres).",
      "required": ["bridges", "services_ro"],
      "additionalProperties": false,
      "properties": {
        "bridges": {
          "type": "array",
          "description": "Bridges requis (par bridge_id). Vérifiés au boot — blocage si absent.",
          "items": {
            "type": "object",
            "required": ["bridge_id", "min_version"],
            "additionalProperties": false,
            "properties": {
              "bridge_id": { "type": "string" },
              "min_version": { "type": "string" },
              "optional": { "type": "boolean", "default": false }
            }
          }
        },
        "services_ro": {
          "type": "array",
          "description": "Services lecture-seule autorisés (jamais write cross-module).",
          "items": {
            "type": "object",
            "required": ["service_id"],
            "additionalProperties": false,
            "properties": {
              "service_id": { "type": "string" },
              "min_version": { "type": "string" },
              "optional": { "type": "boolean", "default": false }
            }
          }
        }
      }
    },
    "migrations": {
      "type": "object",
      "description": "Scope de migration DB du bridge. 1 bridge = 1 scope. Jamais de migration transverse.",
      "required": ["sql_version", "files"],
      "additionalProperties": false,
      "properties": {
        "sql_version": {
          "type": "string",
          "description": "Version courante du schéma DB de ce bridge.",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
        },
        "files": {
          "type": "array",
          "description": "Liste ordonnée des fichiers de migration (relatifs à migrations/).",
          "items": { "type": "string" }
        },
        "rollback_files": {
          "type": "array",
          "description": "Fichiers de rollback correspondant (même ordre).",
          "items": { "type": "string" }
        }
      }
    },
    "deprecation": {
      "type": "object",
      "description": "Statut de dépréciation du bridge. Absent = bridge actif.",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "removed"],
          "description": "active = en production | deprecated = coexistence temporaire | removed = ne doit plus être utilisé."
        },
        "deprecated_since": {
          "type": "string",
          "description": "Version core à partir de laquelle la dépréciation est annoncée.",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
        },
        "removal_target": {
          "type": "string",
          "description": "Version core cible de la suppression définitive.",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
        },
        "alias_for": {
          "type": "string",
          "description": "bridge_id du remplaçant (si alias de compatibilité disponible)."
        },
        "migration_script": {
          "type": "string",
          "description": "Chemin relatif vers le script de migration automatique vers le nouveau bridge."
        },
        "notice": {
          "type": "string",
          "description": "Message affiché en admin + logs + CI pendant la période de coexistence."
        }
      }
    },
    "ci": {
      "type": "object",
      "description": "Contraintes CI/CD pour ce bridge.",
      "additionalProperties": false,
      "properties": {
        "require_signature": {
          "type": "boolean",
          "description": "Si true, la signature RSA est obligatoire pour tout build stable/release.",
          "default": true
        },
        "require_checksums": {
          "type": "boolean",
          "default": true
        },
        "blocking_checks": {
          "type": "array",
          "description": "Checks bloquants (fail = build rejeté).",
          "items": {
            "type": "string",
            "enum": [
              "signature",
              "checksums",
              "compatibility",
              "schema_validation",
              "permissions_declared",
              "migration_scope"
            ]
          }
        }
      }
    }
  }
}
