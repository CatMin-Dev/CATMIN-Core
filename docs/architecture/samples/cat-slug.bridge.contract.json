{
  "schema_version": "1.0.0",
  "bridge_id": "cat-slug",
  "bridge_version": "1.0.0",
  "min_core_version": "0.4.0",
  "permissions": {
    "slug.read": {
      "label": "Lire les slugs",
      "scope": "read",
      "description": "Permet de consulter et résoudre les slugs d'entités.",
      "roles_default": ["admin", "editor", "author"]
    },
    "slug.write": {
      "label": "Créer / modifier les slugs",
      "scope": "write",
      "description": "Permet de créer ou modifier le slug d'une entité. Inclut la génération automatique.",
      "roles_default": ["admin", "editor"]
    },
    "slug.delete": {
      "label": "Supprimer un slug",
      "scope": "delete",
      "description": "Permet de supprimer un slug (avec redirection automatique si applicable).",
      "roles_default": ["admin"]
    },
    "slug.reorder": {
      "label": "Gérer les redirections de slugs",
      "scope": "reorder",
      "description": "Permet de gérer les alias et redirections 301/302 de slugs.",
      "roles_default": ["admin"]
    }
  },
  "widgets": [
    {
      "name": "slug-health-badge",
      "type": "widget",
      "scope": "admin",
      "permissions": ["slug.read"],
      "entry": "widgets/slug-health-badge.php",
      "description": "Badge de qualite des slugs dans les listings admin."
    },
    {
      "name": "slug-inline-suggestion",
      "type": "snippet",
      "scope": "admin",
      "permissions": ["slug.read", "slug.write"],
      "entry": "widgets/slug-inline-suggestion.php",
      "description": "Suggestion de slug lors de l'edition de contenu."
    }
  ],
  "events": {
    "emits": [
      {
        "name": "cat.slug.created",
        "description": "Émis après la création d'un nouveau slug. Consommé par cat-seo-meta, cat-menu-link, cat-search-index.",
        "payload_schema": {
          "type": "object",
          "properties": {
            "slug": { "type": "string" },
            "entity_type": { "type": "string" },
            "entity_id": { "type": "integer" }
          }
        }
      },
      {
        "name": "cat.slug.updated",
        "description": "Émis après modification d'un slug existant. Déclenche la mise à jour des bridges dépendants.",
        "payload_schema": {
          "type": "object",
          "properties": {
            "old_slug": { "type": "string" },
            "new_slug": { "type": "string" },
            "entity_type": { "type": "string" },
            "entity_id": { "type": "integer" }
          }
        }
      },
      {
        "name": "cat.slug.deleted",
        "description": "Émis après suppression d'un slug.",
        "payload_schema": {
          "type": "object",
          "properties": {
            "slug": { "type": "string" },
            "entity_type": { "type": "string" },
            "entity_id": { "type": "integer" }
          }
        }
      }
    ],
    "listens": []
  },
  "routes": [
    {
      "method": "GET",
      "path": "/slugs/{entity_type}/{entity_id}",
      "permission": "slug.read",
      "description": "Retourne le slug actif d'une entité."
    },
    {
      "method": "POST",
      "path": "/slugs/{entity_type}/{entity_id}",
      "permission": "slug.write",
      "description": "Crée ou met à jour le slug d'une entité.",
      "middleware": ["auth", "csrf"]
    },
    {
      "method": "DELETE",
      "path": "/slugs/{entity_type}/{entity_id}",
      "permission": "slug.delete",
      "description": "Supprime le slug d'une entité (conserve la redirection si configuré).",
      "middleware": ["auth", "csrf"]
    },
    {
      "method": "GET",
      "path": "/slugs/resolve/{slug}",
      "permission": "slug.read",
      "description": "Résout un slug vers son entité (entity_type + entity_id)."
    },
    {
      "method": "GET",
      "path": "/slugs/redirects",
      "permission": "slug.reorder",
      "description": "Liste toutes les redirections de slugs actives."
    },
    {
      "method": "POST",
      "path": "/slugs/redirects",
      "permission": "slug.reorder",
      "description": "Ajoute une redirection manuelle de slug.",
      "middleware": ["auth", "csrf"]
    }
  ],
  "dependencies": {
    "bridges": [],
    "services_ro": []
  },
  "migrations": {
    "sql_version": "1.0.0",
    "files": [
      "001-create-mod-cat-slugs.sql",
      "002-create-mod-cat-slug-redirects.sql"
    ],
    "rollback_files": [
      "001-rollback-mod-cat-slugs.sql",
      "002-rollback-mod-cat-slug-redirects.sql"
    ]
  },
  "deprecation": {
    "status": "active"
  },
  "ci": {
    "require_signature": true,
    "require_checksums": true,
    "blocking_checks": [
      "signature",
      "checksums",
      "compatibility",
      "schema_validation",
      "permissions_declared",
      "migration_scope"
    ]
  }
}
