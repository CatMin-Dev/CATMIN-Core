Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to sensitive directories when root is exposed.
    RewriteRule ^(core|config|database|db|storage|sessions|tmp|cache|logs)(/|$) - [F,L,NC]

    # Serve public static assets directly from /public.
    RewriteRule ^(assets/.*)$ public/$1 [L,NC]
    RewriteRule ^(favicon\.png|robots\.txt)$ public/$1 [L,NC]

    # Entry points.
    RewriteRule ^admin/?$ public/admin.php [L,NC,QSA]
    RewriteRule ^install/?$ public/install.php [L,NC,QSA]

    # Fallback to front controller.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
