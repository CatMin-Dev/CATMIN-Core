{
  "name": "CATMIN Forms",
  "slug": "catmin-forms",
  "description": "Formulaires publics configurables avec soumissions admin et mapping metier.",
  "version": "1.0.0",
  "author": "CATMIN Team",
  "required_core_version": "4.0.0",
  "required_php_version": "8.3.0",
  "enabled": true,
  "dependencies": [],
  "required_modules": [
    "core",
    "users",
    "settings",
    "logger"
  ],
  "category": "business",
  "has_routes": true,
  "has_migrations": true,
  "has_assets": false,
  "has_views": true,
  "has_events": false,
  "entrypoints": {
    "admin_routes": "routes.php",
    "docs": "Docs/README.md",
    "permissions": "Permissions/permissions.php"
  },
  "permissions_declared": [
    "module.forms.menu",
    "module.forms.list",
    "module.forms.create",
    "module.forms.edit",
    "module.forms.delete",
    "module.forms.submissions"
  ]
}
