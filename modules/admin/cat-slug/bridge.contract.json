{
  "schema_version": "1.0.0",
  "bridge_id": "cat-slug",
  "bridge_version": "1.0.0",
  "min_core_version": "0.4.0",
  "permissions": {
    "slug.read": {
      "label": "Lire les slugs",
      "scope": "read",
      "description": "Consulter, resoudre et verifier les slugs.",
      "roles_default": ["admin", "editor", "author"]
    },
    "slug.write": {
      "label": "Ecrire les slugs",
      "scope": "write",
      "description": "Generer, normaliser et reserver un slug.",
      "roles_default": ["admin", "editor"]
    },
    "slug.delete": {
      "label": "Supprimer les slugs",
      "scope": "delete",
      "description": "Retirer un slug de la registry.",
      "roles_default": ["admin"]
    },
    "slug.reorder": {
      "label": "Gerer les variantes",
      "scope": "reorder",
      "description": "Gerer les variantes et suffixes de collisions.",
      "roles_default": ["admin"]
    }
  },
  "widgets": [
    {
      "name": "slug-registry-health",
      "type": "widget",
      "scope": "admin",
      "permissions": ["slug.read"],
      "entry": "widgets/slug-registry-health.php",
      "description": "Indicateur de collisions et coherence registry."
    },
    {
      "name": "slug-live-suggestion",
      "type": "snippet",
      "scope": "admin",
      "permissions": ["slug.read", "slug.write"],
      "entry": "widgets/slug-live-suggestion.php",
      "description": "Suggestion de slug depuis un texte source."
    }
  ],
  "events": {
    "emits": [
      {
        "name": "cat.slug.created",
        "description": "Slug reserve pour une entite"
      },
      {
        "name": "cat.slug.updated",
        "description": "Slug primaire modifie"
      },
      {
        "name": "cat.slug.deleted",
        "description": "Slug supprime"
      }
    ],
    "listens": []
  },
  "routes": [
    {
      "method": "GET",
      "path": "/modules/slug-bridge",
      "permission": "slug.read",
      "description": "Page admin registry des slugs"
    },
    {
      "method": "POST",
      "path": "/modules/slug-bridge/generate",
      "permission": "slug.write",
      "description": "Generer et reserver un slug"
    },
    {
      "method": "POST",
      "path": "/modules/slug-bridge/validate",
      "permission": "slug.read",
      "description": "Valider un slug dans un scope"
    }
  ],
  "dependencies": {
    "bridges": [],
    "services_ro": []
  },
  "migrations": {
    "sql_version": "1.0.0",
    "files": [
      "001_create_mod_cat_slug_registry.php"
    ],
    "rollback_files": []
  },
  "deprecation": {
    "status": "active"
  },
  "ci": {
    "require_signature": false,
    "require_checksums": true,
    "blocking_checks": [
      "checksums",
      "compatibility",
      "schema_validation",
      "permissions_declared",
      "migration_scope"
    ]
  }
}
