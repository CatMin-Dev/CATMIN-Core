{
  "bridge": "cat-seo-meta",
  "version": "1.0.0-dev.1",
  "kind": "transversal",
  "services": [
    "SeoMetaService",
    "SeoScoreService",
    "SeoAuditService",
    "SeoPreviewService",
    "SeoIntegrationService"
  ],
  "endpoints": [
    "/modules/seo-meta",
    "/modules/seo-meta/save",
    "/modules/seo-meta/audit"
  ],
  "widgets": [
    "seo_score_badge",
    "missing_meta_alert",
    "social_preview",
    "seo_score_meter",
    "seo_quick_summary"
  ],
  "consumers": [
    "cat-page",
    "cat-blog",
    "cat-directory"
  ]
}
