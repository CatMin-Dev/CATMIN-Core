{
  "bridge": "cat-seo-meta",
  "version": "1.0.0-dev.2",
  "kind": "transversal",
  "services": [
    "SeoMetaService",
    "SeoScoreService",
    "SeoAuditService",
    "SeoPreviewService",
    "SeoIntegrationService"
  ],
  "endpoints": [
    "/modules/seo-meta",
    "/modules/seo-meta/save",
    "/modules/seo-meta/audit"
  ],
  "widgets": [
    "seo_score_badge",
    "missing_meta_alert",
    "social_preview",
    "seo_score_meter",
    "seo_quick_summary"
  ],
  "consumers": [
    "cat-page",
    "cat-blog",
    "cat-directory"
  ],
  "consumer_policy": {
    "mandatory": true,
    "required_modules": [
      "cat-slug",
      "cat-seo-meta"
    ],
    "panel_hook": "content.editor.panels"
  }
}
