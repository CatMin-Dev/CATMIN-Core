{
  "bridge": "cat-tags",
  "version": "1.0.0-dev.1",
  "kind": "transversal",
  "services": [
    "TagsService",
    "TagAutocompleteService",
    "TagLinkService",
    "TagUsageService",
    "TagDisplayService"
  ],
  "endpoints": [
    "/modules/tags-bridge",
    "/modules/tags-bridge/sync",
    "/modules/tags-bridge/suggest"
  ],
  "widgets": [
    "tags_chips_admin",
    "tags_list_comma_front",
    "tags_badges_front",
    "tag_cloud_front",
    "usage_badge_admin"
  ],
  "consumers": [
    "cat-page",
    "cat-blog",
    "cat-directory"
  ],
  "consumer_policy": {
    "mandatory": true,
    "required_modules": [
      "cat-seo-meta",
      "cat-tags"
    ],
    "panel_hook": "content.editor.panels"
  }
}
