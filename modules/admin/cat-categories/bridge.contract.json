{
  "bridge": "cat-categories",
  "version": "1.0.0-dev.1",
  "kind": "transversal",
  "services": [
    "CategoriesService",
    "CategoryTreeService",
    "CategoryLinkService",
    "CategoryUsageService",
    "CategorySelectorService"
  ],
  "endpoints": [
    "/modules/categories-bridge",
    "/modules/categories-bridge/create",
    "/modules/categories-bridge/sync",
    "/modules/categories-bridge/tree"
  ],
  "widgets": [
    "category_badge_admin",
    "category_pills_front",
    "category_breadcrumb",
    "category_tree_selector_admin"
  ],
  "consumers": [
    "cat-page",
    "cat-blog",
    "cat-directory",
    "cat-products"
  ],
  "consumer_policy": {
    "mandatory": true,
    "required_modules": [
      "cat-seo-meta",
      "cat-tags",
      "cat-categories"
    ],
    "panel_hook": "content.editor.panels"
  }
}
