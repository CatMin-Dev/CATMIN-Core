.env
.env.local
.env.production

# Runtime data
storage/logs/*.log
storage/cache/*
storage/install/sessions/*
storage/updates/releases/*
storage/updates/reports/*
logs/*.log
cache/*
sessions/*
tmp/*

# Keep runtime dirs tracked
!storage/cache/.gitkeep
!storage/logs/.gitkeep
!storage/backups/.gitkeep
!storage/updates/releases/.gitkeep
!storage/updates/reports/.gitkeep
!storage/install/sessions/.gitkeep
!cache/.gitkeep
!logs/.gitkeep
!sessions/.gitkeep
!tmp/.gitkeep

# Tooling
.vscode/
node_modules/

# Runtime artifacts that must not be versioned
storage/install/*
!storage/install/.gitkeep
!storage/install/sessions/
!storage/install/sessions/.gitkeep
!storage/install/reports/
!storage/install/reports/.gitkeep
storage/config/runtime.json
db/database.sqlite
logs/version-history.json

# Local backups
storage/backups/*.zip
